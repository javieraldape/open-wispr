    "typescript": "~5.6.3",
    "vite": "^6.4.3"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "brace-expansion": "1.1.15",
    "flatted": "3.4.2",
    "js-yaml": "4.3.0",
    "picomatch": "4.0.5",
    "postcss": "8.5.16",
    "rollup": "4.62.2",
    "yaml": "1.10.3"
